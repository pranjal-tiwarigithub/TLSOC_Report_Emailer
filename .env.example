# ---------------------------------------------------------------------------
# Daily Report Sender — environment template
#
# Copy this file to ".env" and fill in real values:
#     cp .env.example .env
#
# The real ".env" is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Directory to monitor for the latest PDF report. CONFIGURABLE — do not
# hardcode this anywhere in the code. The production value is shown here.
REPORT_DIR=/opt/TLSOCDockerDeploy/reporting/output/pdf

# Logging configuration.
# LOG_LEVEL: one of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
# LOG_FILE: path to the rotating log file (relative paths resolve from the
# project root).
LOG_FILE=logs/sender.log

# ---------------------------------------------------------------------------
# Gmail SMTP settings
# ---------------------------------------------------------------------------
# Defaults are correct for Gmail; usually you only fill in the values below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SECRETS — your Gmail address and a 16-character App Password (NOT your normal
# Google password). Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account).
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Sender address shown in the "From" field. Leave blank to reuse SMTP_USER.
EMAIL_FROM=your_gmail_address@gmail.com

# Admin address(es) that receive a failure alert if a run fails (comma-separated).
ALERT_EMAIL_TO=admin@example.com

# ---------------------------------------------------------------------------
# Reports (multi-report, per-type sending)
# ---------------------------------------------------------------------------
# Department/brand name shown in every email subject and body, e.g.
#   "<DEPARTMENT> Daily <Type> Report - 2026-07-17".
DEPARTMENT=TLSOC

# The report categories this deployment sends (comma-separated). Each category
# is the 2nd word of a file named "daily_<category>_<subtype>_<YYYY-MM-DD>.pdf"
# in REPORT_DIR (e.g. daily_mail_postfix_2026-07-21.pdf), and has its own
# recipients below. The 3rd word (subtype, e.g. postfix/squid/nginx) does NOT
# affect routing — it is shown in the email subject. Only categories listed here
# are sent; a PDF of any other category is skipped and reported in the admin alert.
REPORT_TYPES=web,mail,proxy

# Per-category recipients — one To/CC/BCC group per category, suffixed with the
# UPPERCASED category name. CC and BCC may be left empty. Add a new category by
# adding it to REPORT_TYPES above and adding its EMAIL_*_<CATEGORY> lines here.
EMAIL_TO_WEB=web-team@example.com
EMAIL_CC_WEB=
EMAIL_BCC_WEB=

EMAIL_TO_MAIL=mail-team@example.com
EMAIL_CC_MAIL=
EMAIL_BCC_MAIL=

EMAIL_TO_PROXY=proxy-team@example.com
EMAIL_CC_PROXY=
EMAIL_BCC_PROXY=
